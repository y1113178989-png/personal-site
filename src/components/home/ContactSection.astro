---
import { t } from '../../i18n/ui';
import Icon from '../ui/Icon.astro';

const { site, locale } = Astro.props;
const { email, github, linkedin } = site?.data ?? {};
const title = t(locale, 'nav.contact');
---

<section class="contact section" id="contact">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title">{title}</h2>
    </div>
    <div class="contact-grid reveal-stagger">
      {github && (
        <a href={github} class="contact-card card" target="_blank" rel="noopener noreferrer">
          <div class="contact-icon"><Icon name="github" size={24} /></div>
          <div>
            <div class="contact-label">{t(locale, 'contact.github')}</div>
            <div class="contact-handle">{new URL(github).pathname.slice(1)}</div>
          </div>
        </a>
      )}
      {email && (
        <a href={`mailto:${email}`} class="contact-card card">
          <div class="contact-icon"><Icon name="email" size={24} /></div>
          <div>
            <div class="contact-label">{t(locale, 'contact.email')}</div>
            <div class="contact-handle">{email}</div>
          </div>
        </a>
      )}
      {linkedin && (
        <a href={linkedin} class="contact-card card" target="_blank" rel="noopener noreferrer">
          <div class="contact-icon"><Icon name="linkedin" size={24} /></div>
          <div>
            <div class="contact-label">LinkedIn</div>
            <div class="contact-handle">{new URL(linkedin).pathname.slice(1)}</div>
          </div>
        </a>
      )}
    </div>

    <div class="resume-wrap reveal">
      <a href="/resume.pdf" class="btn-primary resume-btn" download>
        <Icon name="download" size={18} />
        {t(locale, 'contact.resume')}
      </a>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .contact-card {
    display: flex !important;
    align-items: center;
    gap: var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    padding: var(--space-md);
  }
  .contact-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }
  .contact-label {
    font-weight: 600;
    font-size: var(--text-sm);
    margin-bottom: 2px;
  }
  .contact-handle {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }
  .resume-wrap {
    text-align: center;
  }
  .resume-btn {
    display: inline-flex !important;
    align-items: center;
    gap: var(--space-xs);
  }
</style>
