---
const { experience, locale } = Astro.props;
const title = experience?.data?.title ?? (locale === 'zh' ? '工作经历' : 'Experience');
const jobs = experience?.data?.jobs ?? [];
---

<section class="experience section section-alt" id="experience">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title">{title}</h2>
    </div>
    <div class="job-grid reveal-stagger">
      {jobs.map((job: any, i: number) => (
        <div class="job-card card">
          <div class="job-card-header">
            <span class="job-company-badge">{job.company}</span>
            <span class="job-date">
              {job.startDate} — {job.endDate || (locale === 'zh' ? '至今' : 'Present')}
            </span>
          </div>
          <h3 class="job-role">{job.role}</h3>
          <p class="job-desc">{job.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .job-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .job-card {
    position: relative;
  }
  .job-card:first-child {
    border-left: 3px solid var(--color-accent);
  }
  .job-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-xs);
  }
  .job-company-badge {
    display: inline-block;
    padding: 0.2em 0.75em;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    border-radius: 100px;
  }
  .job-date {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .job-role {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }
  .job-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
</style>
