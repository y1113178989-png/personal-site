---
const { site, locale } = Astro.props;
const name = site?.data?.name ?? 'Name';
const tagline = site?.data?.tagline ?? '';
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="container hero-content">
    <div class="hero-text reveal">
      <p class="hero-greeting">{locale === 'zh' ? '你好，我是' : 'Hi, I&rsquo;m'}</p>
      <h1 class="hero-name">{name}</h1>
      <p class="hero-tagline">{tagline}</p>
      <div class="hero-cta">
        <a href="#experience" class="btn-primary">{locale === 'zh' ? '查看我的经历' : 'View My Work'}</a>
        <a href="#contact" class="btn-outline">{locale === 'zh' ? '联系我' : 'Contact Me'}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: var(--space-3xl) var(--space-2xl);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-accent-subtle) 0%, var(--color-bg) 50%, var(--color-accent-subtle) 100%);
    z-index: 0;
  }
  .hero-bg::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--color-accent-light) 0%, transparent 70%);
    opacity: 0.15;
    border-radius: 50%;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, var(--color-gradient-2) 0%, transparent 70%);
    opacity: 0.12;
    border-radius: 50%;
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .hero-greeting {
    font-size: var(--text-lg);
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    font-weight: 500;
  }
  .hero-name {
    font-size: var(--text-4xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-sm);
    background: linear-gradient(135deg, var(--color-gradient-1), var(--color-gradient-2), var(--color-gradient-3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }
  .hero-cta {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75em 1.75em;
    font-size: var(--text-sm);
    font-weight: 600;
    color: #fff;
    background: linear-gradient(135deg, var(--color-gradient-1), var(--color-gradient-2));
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 16px rgba(79, 70, 229, 0.3);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(79, 70, 229, 0.4);
    text-decoration: none;
  }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    padding: 0.75em 1.75em;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .btn-outline:hover {
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: var(--space-2xl) var(--space-xl);
    }
    .hero-name {
      font-size: var(--text-3xl);
    }
  }
</style>
